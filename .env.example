# superbrain environment variables
#
# Copy this file to `.env` and fill in the values the backend / scrapers need.
# Never commit a real `.env` — it is gitignored.

# Lake location (local dev default)
SUPERBRAIN_LAKE_PATH=./data/lake
SUPERBRAIN_DUCKDB_PATH=./data/superbrain.duckdb

# Backend
SUPERBRAIN_API_HOST=127.0.0.1
SUPERBRAIN_API_PORT=8000
SUPERBRAIN_LOG_LEVEL=INFO

# Bearer tokens — one per owner. Comma-separated.
# Mint via the SPA Settings page once the backend is up; for local dev, use a dummy.
SUPERBRAIN_API_TOKENS=dev-token

# CORS: comma-separated list of allowed browser origins for the SPA.
SUPERBRAIN_CORS_ORIGINS=http://localhost:5273,http://localhost:3000

# Optional: override the inbound/outbound request-id header (default x-request-id).
# SUPERBRAIN_REQUEST_ID_HEADER=x-request-id

# Optional: echoed from /health for quick deploy-sanity checks.
# SUPERBRAIN_GIT_SHA=

# CI / scraper uploads (used by GitHub Actions and local `python -m superbrain.scrapers.run`)
SUPERBRAIN_INGEST_URL=http://127.0.0.1:8000
SUPERBRAIN_INGEST_TOKEN=dev-token

# Alerts (phase 8)
# Thresholds — bets must clear BOTH the edge and probability floors.
SUPERBRAIN_ALERT_EDGE_THRESHOLD=0.05
SUPERBRAIN_ALERT_MIN_PROBABILITY=0.35
# Caps — guardrails against Telegram/email spam in a single sweep.
SUPERBRAIN_ALERT_MAX_PER_RUN=20
SUPERBRAIN_ALERT_MAX_PER_MATCH=3
# Dedup window in hours. Alerts already delivered to ≥1 channel inside this
# rolling window are suppressed; an alert that failed on every channel stays
# eligible for re-delivery.
SUPERBRAIN_ALERT_DEDUP_WINDOW_HOURS=24
# Fan-out per channel per alert (e.g. telegram chat ids).
SUPERBRAIN_ALERT_CONCURRENCY=4
# How far into the future the scheduler walks when pricing fixtures.
SUPERBRAIN_ALERT_LOOKAHEAD_HOURS=48
# Parquet sink for deduplication and auditing.
SUPERBRAIN_ALERT_SINK_PATH=./data/alerts/sent_alerts.parquet

# Telegram delivery — leave BOT_TOKEN or CHAT_IDS blank to disable the channel.
# CHAT_IDS is comma-separated (one message per id per alert).
SUPERBRAIN_TELEGRAM_BOT_TOKEN=
SUPERBRAIN_TELEGRAM_CHAT_IDS=

# Email delivery — leave SMTP_HOST or EMAIL_RECIPIENTS blank to disable.
# RECIPIENTS is comma-separated; a single batched email goes out per sweep.
SUPERBRAIN_SMTP_HOST=
SUPERBRAIN_SMTP_PORT=465
SUPERBRAIN_SMTP_USER=
SUPERBRAIN_SMTP_PASSWORD=
SUPERBRAIN_SMTP_FROM=
SUPERBRAIN_ALERT_EMAIL_RECIPIENTS=

# Scheduling toggles (in-process APScheduler on the Fly.io backend)
SUPERBRAIN_SCHEDULER_ENABLED=true
SUPERBRAIN_SCRAPE_INTERVAL_LIVE_SECONDS=120
SUPERBRAIN_SCRAPE_INTERVAL_PREMATCH_SECONDS=900
