# superbrain environment variables
#
# Copy this file to `.env` and fill in the values the backend / scrapers need.
# Never commit a real `.env` — it is gitignored.

# Lake location (local dev default)
SUPERBRAIN_LAKE_PATH=./data/lake
SUPERBRAIN_DUCKDB_PATH=./data/superbrain.duckdb

# Backend
SUPERBRAIN_API_HOST=127.0.0.1
SUPERBRAIN_API_PORT=8000
SUPERBRAIN_LOG_LEVEL=INFO

# Bearer tokens — one per owner. Comma-separated.
# Mint via the SPA Settings page once the backend is up; for local dev, use a dummy.
SUPERBRAIN_API_TOKENS=dev-token

# CORS: comma-separated list of allowed browser origins for the SPA.
SUPERBRAIN_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: override the inbound/outbound request-id header (default x-request-id).
# SUPERBRAIN_REQUEST_ID_HEADER=x-request-id

# Optional: echoed from /health for quick deploy-sanity checks.
# SUPERBRAIN_GIT_SHA=

# CI / scraper uploads (used by GitHub Actions and local `python -m superbrain.scrapers.run`)
SUPERBRAIN_INGEST_URL=http://127.0.0.1:8000
SUPERBRAIN_INGEST_TOKEN=dev-token

# Telegram alerts (phase 10)
SUPERBRAIN_TELEGRAM_BOT_TOKEN=
SUPERBRAIN_TELEGRAM_CHAT_ID=

# Scheduling toggles (in-process APScheduler on the Fly.io backend)
SUPERBRAIN_SCHEDULER_ENABLED=true
SUPERBRAIN_SCRAPE_INTERVAL_LIVE_SECONDS=120
SUPERBRAIN_SCRAPE_INTERVAL_PREMATCH_SECONDS=900
