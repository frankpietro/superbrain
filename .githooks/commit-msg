#!/usr/bin/env bash
# Enforce Conventional Commits: <type>(optional-scope)!: <subject>
# See https://www.conventionalcommits.org/
#
# Seeded from Gaia (https://github.com/frankpietro/gaia). Do not edit in-place; change upstream and
# re-seed with `gaia update`.
set -euo pipefail

msg_file="$1"
first_line="$(head -n1 "$msg_file")"

# Allow merge/revert commits generated by git or gh.
if [[ "$first_line" =~ ^(Merge|Revert) ]]; then
  exit 0
fi

pattern='^(build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test)(\([a-z0-9._-]+\))?!?: .{1,100}$'

if ! [[ "$first_line" =~ $pattern ]]; then
  cat >&2 <<EOF
Commit message does not follow Conventional Commits.

Received:
  $first_line

Expected format:
  <type>(optional-scope)!: <subject>

Allowed types: build, chore, ci, docs, feat, fix, perf, refactor, revert, style, test
Examples:
  feat(auth): add session refresh
  fix(ui): debounce search input
  docs: describe onboarding flow
  feat(api)!: rename /history to /sales

EOF
  exit 1
fi
